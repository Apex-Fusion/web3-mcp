# Vector MCP Server Configuration
# ================================

# Vector Network Endpoints
VECTOR_OGMIOS_URL=https://ogmios.vector.testnet.apexfusion.org
VECTOR_KOIOS_URL=https://koios.vector.testnet.apexfusion.org/
VECTOR_SUBMIT_URL=https://submit.vector.testnet.apexfusion.org/api/submit/tx
VECTOR_EXPLORER_URL=https://vector.testnet.apexscan.org

# Wallet Configuration
VECTOR_MNEMONIC=word1 word2 word3 ... word15   # Must be exactly 15 or 24 words
VECTOR_ACCOUNT_INDEX=0                          # Wallet account index (default: 0)

# Safety Limits (in lovelace, 1 ADA = 1,000,000 lovelace)
VECTOR_SPEND_LIMIT_PER_TX=100000000             # 100 ADA per transaction
VECTOR_SPEND_LIMIT_DAILY=500000000              # 500 ADA daily limit
