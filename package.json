{
  "name": "vector-mcp-server",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "bin": {
    "vector-mcp": "./build/index.js"
  },
  "scripts": {
    "clean": "rm -rf build",
    "build": "npm run clean && NODE_OPTIONS='--max-old-space-size=8192' tsc && chmod +x build/index.js",
    "start": "node build/index.js"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "vector",
    "mcp",
    "blockchain",
    "cardano",
    "apex-fusion",
    "ai-agent",
    "utxo"
  ],
  "author": "Apex Fusion",
  "license": "ISC",
  "description": "MCP server for Vector blockchain — AI agent interface for Apex Fusion's L2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Apex-Fusion/vector-ai-agents.git"
  },
  "homepage": "https://github.com/Apex-Fusion/vector-ai-agents#readme",
  "bugs": {
    "url": "https://github.com/Apex-Fusion/vector-ai-agents/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.1",
    "cross-fetch": "^4.0.0",
    "dotenv": "^16.4.5",
    "lucid-cardano": "^0.10.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "typescript": "^5.7.3"
  }
}
