{
  "name": "vector-mcp-server",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "bin": {
    "vector-mcp": "./build/index.js"
  },
  "scripts": {
    "postinstall": "ln -sf ../../../libsodium-sumo/dist/modules-sumo-esm/libsodium-sumo.mjs node_modules/libsodium-wrappers-sumo/dist/modules-sumo-esm/libsodium-sumo.mjs 2>/dev/null || true",
    "clean": "rm -rf build",
    "build": "tsup && chmod +x build/index.js",
    "typecheck": "tsc --noEmit --incremental",
    "start": "node build/index.js",
    "test": "npm run build && node --import tsx --test test/run.test.ts"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "vector",
    "mcp",
    "blockchain",
    "cardano",
    "apex-fusion",
    "ai-agent",
    "utxo"
  ],
  "author": "Apex Fusion",
  "license": "ISC",
  "description": "MCP server for Vector blockchain — AI agent interface for Apex Fusion's L2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Apex-Fusion/vector-ai-agents.git"
  },
  "homepage": "https://github.com/Apex-Fusion/vector-ai-agents#readme",
  "bugs": {
    "url": "https://github.com/Apex-Fusion/vector-ai-agents/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.1",
    "cross-fetch": "^4.0.0",
    "dotenv": "^16.4.5",
    "@lucid-evolution/lucid": "^0.4.29",
    "@noble/hashes": "^1.7.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
